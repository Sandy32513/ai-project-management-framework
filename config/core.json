{
  "framework": {
    "name": "AI Project Management Core Engine",
    "version": "1.0.0",
    "author": "Framework Core Team",
    "description": "Core routing, escalation, and decision logic engine"
  },
  "modules": {
    "routing": {
      "description": "Project and task routing to appropriate roles",
      "strategies": [
        "skill_based",
        "priority_based",
        "availability_based",
        "load_balanced"
      ],
      "filters": {
        "required": ["department", "skill_match", "authority_level"],
        "optional": ["current_load", "expertise_area", "availability"]
      }
    },
    "escalation": {
      "description": "Issue and task escalation management",
      "triggers": [
        {
          "type": "timeout",
          "threshold": "24h",
          "action": "escalate_one_level"
        },
        {
          "type": "priority",
          "threshold": "critical",
          "action": "escalate_immediately"
        },
        {
          "type": "budget",
          "threshold": "10%_over",
          "action": "escalate_to_manager"
        },
        {
          "type": "security",
          "threshold": "any",
          "action": "escalate_to_ciso"
        }
      ]
    },
    "decision": {
      "description": "Decision-making authority and logic",
      "levels": [
        {
          "level": 1,
          "authority": "routine",
          "handlers": ["Intern", "Junior Engineer", "Junior Developer", "QA Intern", "DevOps Intern", "Helpdesk Technician"],
          "threshold": "low_impact",
          "budget_limit": 0
        },
        {
          "level": 2,
          "authority": "standard",
          "handlers": ["Mid-Level Engineer", "Software Engineer", "QA Engineer", "DevOps Engineer", "IT Support Engineer", "Data Analyst"],
          "threshold": "low_medium_impact",
          "budget_limit": 1000
        },
        {
          "level": 3,
          "authority": "complex",
          "handlers": ["Senior Engineer", "Senior Developer", "Tech Lead", "Team Lead", "QA Lead", "Senior QA Engineer", "Security Engineer", "Principal Engineer", "UX Lead", "Data Scientist"],
          "threshold": "medium_impact",
          "budget_limit": 10000
        },
        {
          "level": 4,
          "authority": "strategic",
          "handlers": ["Manager", "Engineering Manager", "Product Manager", "DevOps Lead", "UX Lead", "Sales Manager", "QA Director", "Design Director", "DevOps Manager", "Product Director", "Security Director"],
          "threshold": "medium_high_impact",
          "budget_limit": 50000
        },
        {
          "level": 5,
          "authority": "executive",
          "handlers": ["Director", "VP", "VP Engineering", "VP Product", "VP Sales", "VP DevOps", "Head of Data", "Design Director", "Cloud Architect"],
          "threshold": "high_impact",
          "budget_limit": 500000
        },
        {
          "level": 6,
          "authority": "company_wide",
          "handlers": ["CEO", "CTO", "CFO", "COO", "CCO", "CIO", "CISO"],
          "threshold": "critical_impact",
          "budget_limit": null
        }
      ]
    },
    "resource_allocation": {
      "description": "Dynamic resource distribution",
      "algorithms": [
        "priority_weighted",
        "skill_matched",
        "load_balanced",
        "cost_optimized"
      ],
      "constraints": {
        "max_concurrent_tasks": 5,
        "budget_limits": "by_department",
        "availability_check": true
      }
    }
  },
  "automation": {
    "project_routing": {
      "enabled": true,
      "triggers": ["new_project", "project_update", "priority_change"],
      "action": "route_to_appropriate_team"
    },
    "ticket_monitoring": {
      "enabled": true,
      "interval": "15min",
      "actions": ["status_update", "escalation_check", "SLA_check"]
    },
    "deployment_approval": {
      "enabled": true,
      "stages": ["dev", "staging", "production"],
      "auto_approve_conditions": ["all_tests_pass", "security_scan_clean"]
    },
    "reporting": {
      "enabled": true,
      "schedules": {
        "daily": ["ticket_summary", "active_projects"],
        "weekly": ["department_summary", "resource_utilization"],
        "monthly": ["executive_summary", "audit_report"]
      },
      "final_recipient": "CEO"
    }
  }
}