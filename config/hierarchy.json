      ]
    },
    "devops": {
      "levels": [
        { "role": "VP DevOps", "authority": "department", "reportsTo": "CTO" },
        { "role": "DevOps Manager", "authority": "team", "reportsTo": "VP DevOps" },
        { "role": "DevOps Lead", "authority": "technical", "reportsTo": "DevOps Manager" },
        { "role": "Cloud Architect", "authority": "architecture", "reportsTo": "VP DevOps" },
        { "role": "Senior DevOps Engineer", "authority": "complex_problems", "reportsTo": "DevOps Lead" },
        { "role": "DevOps Engineer", "authority": "operations", "reportsTo": "Senior DevOps Engineer" },
        { "role": "DevOps Intern", "authority": "learning", "reportsTo": "DevOps Engineer" }
      ]
    },
    "security": {
      "levels": [
        { "role": "CISO", "authority": "security", "reportsTo": "CEO" },
        { "role": "Security Director", "authority": "department", "reportsTo": "CISO" },
        { "role": "Security Architect", "authority": "architecture", "reportsTo": "Security Director" },
        { "role": "Security Engineer", "authority": "implementation", "reportsTo": "Security Architect" },
        { "role": "SOC Analyst", "authority": "monitoring", "reportsTo": "Security Engineer" },
        { "role": "Security Intern", "authority": "learning", "reportsTo": "SOC Analyst" }
      ]
    },
    "data": {
      "levels": [
        { "role": "Head of Data", "authority": "department", "reportsTo": "CTO" },
        { "role": "Data Architect", "authority": "architecture", "reportsTo": "Head of Data" },
        { "role": "Data Scientist", "authority": "analysis", "reportsTo": "Data Architect" },
        { "role": "Data Analyst", "authority": "reporting", "reportsTo": "Data Scientist" },
        { "role": "Data Intern", "authority": "learning", "reportsTo": "Data Analyst" }
      ]
