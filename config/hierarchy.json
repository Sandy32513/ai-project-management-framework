        { "role": "Senior Engineer", "authority": "complex_problems", "reportsTo": "Team Lead" },
        { "role": "Mid-Level Engineer", "authority": "features", "reportsTo": "Senior Engineer" },
        { "role": "Junior Engineer", "authority": "basic_tasks", "reportsTo": "Team Lead" },
        { "role": "Intern", "authority": "learning", "reportsTo": "Junior Engineer" }
