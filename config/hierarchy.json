        { "role": "UI/UX Designer", "authority": "design", "reportsTo": "UX Lead" },
        { "role": "Visual Designer", "authority": "design", "reportsTo": "UX Lead" },
        { "role": "Design Intern", "authority": "learning", "reportsTo": "Visual Designer" }
      ]
    },
    "qa": {
      "levels": [
        { "role": "QA Director", "authority": "department", "reportsTo": "VP Engineering" },
        { "role": "QA Lead", "authority": "team", "reportsTo": "QA Director" },
        { "role": "Senior QA Engineer", "authority": "complex_testing", "reportsTo": "QA Lead" },
        { "role": "QA Engineer", "authority": "testing", "reportsTo": "Senior QA Engineer" },
