    "sales": {
      "levels": [
        { "role": "VP Sales", "authority": "department", "reportsTo": "CEO" },
        { "role": "Sales Manager", "authority": "team", "reportsTo": "VP Sales" },
        { "role": "Account Executive", "authority": "sales", "reportsTo": "Sales Manager" },
        { "role": "Business Analyst", "authority": "analysis", "reportsTo": "Sales Manager" }
      ]
