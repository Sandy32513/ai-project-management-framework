{
  "framework": {
    "name": "AI Project Management Skill Set",
    "version": "1.0.0",
    "description": "Standalone autonomous project management framework mirroring company hierarchy"
  },
  "hierarchy": {
    "executive": {
      "levels": [
        { "role": "CEO", "authority": "company_wide", "reportsTo": null },
        { "role": "CTO", "authority": "technology", "reportsTo": "CEO" },
        { "role": "CIO", "authority": "internal_it", "reportsTo": "CEO" },
        { "role": "CFO", "authority": "financial", "reportsTo": "CEO" },
        { "role": "COO", "authority": "operations", "reportsTo": "CEO" },
        { "role": "CCO", "authority": "commercial", "reportsTo": "CEO" },
        { "role": "CISO", "authority": "security", "reportsTo": "CEO" }
      ]
    },
    "senior_leadership": {
      "levels": [
        { "role": "VP", "authority": "department", "reportsTo": "C-Suite" },
        { "role": "Director", "authority": "multi_team", "reportsTo": "VP" },
        { "role": "Senior Manager", "authority": "team_group", "reportsTo": "Director" }
      ]
    },
    "mid_leadership": {
      "levels": [
        { "role": "Manager", "authority": "team", "reportsTo": "Senior Manager" },
        { "role": "Team Lead", "authority": "technical", "reportsTo": "Manager" }
      ]
    },
    "individual_contributors": {
      "levels": [
        { "role": "Principal Engineer", "authority": "architecture", "reportsTo": "CTO" },
        { "role": "Senior Engineer", "authority": "complex_problems", "reportsTo": "Team Lead" },
        { "role": "Mid-Level Engineer", "authority": "features", "reportsTo": "Senior Engineer" },
        { "role": "Junior Engineer", "authority": "basic_tasks", "reportsTo": "Mid-Level Engineer" },
        { "role": "Intern", "authority": "learning", "reportsTo": "Junior Engineer" }
      ]
    }
  },
  "departments": [
    "Engineering",
    "Product",
    "Design",
    "QA",
    "DevOps",
    "Security",
    "Data",
    "Sales",
    "Marketing",
    "IT Support",
    "Customer Success"
  ],
  "escalation": {
    "tiers": [
      { "tier": 1, "from": "Individual Contributor", "to": "Team Lead/Manager", "timeout": "24h" },
      { "tier": 2, "from": "Manager", "to": "Director/VP", "timeout": "48h" },
      { "tier": 3, "from": "Director/VP", "to": "C-Suite", "timeout": "72h" }
    ],
    "triggers": [
      "priority_critical",
      "budget_exceeded",
      "timeline_at_risk",
      "security_breach",
      "resource_conflict"
    ]
  },
  "routing": {
    "default_strategy": "skill_match",
    "fallback_strategy": "round_robin",
    "filters": ["priority", "department", "skill_required"]
  },
  "audit": {
    "enabled": true,
    "frequency": "weekly",
    "recipients": ["CEO"],
    "formats": ["json", "pdf", "html"]
  },
  "deployment": {
    "approval_levels": [
      { "level": 1, "role": "Team Lead", "environment": "development" },
      { "level": 2, "role": "Manager", "environment": "staging" },
      { "level": 3, "role": "Director", "environment": "production" },
      { "level": 4, "role": "CTO", "environment": "production_critical" }
    ]
  }
}