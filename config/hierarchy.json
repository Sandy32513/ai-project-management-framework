      ]
    },
    "it_support": {
      "levels": [
        { "role": "IT Manager", "authority": "department", "reportsTo": "CIO" },
        { "role": "System Admin", "authority": "infrastructure", "reportsTo": "IT Manager" },
        { "role": "IT Support Engineer", "authority": "support", "reportsTo": "System Admin" },
        { "role": "Helpdesk Technician", "authority": "support", "reportsTo": "IT Support Engineer" },
        { "role": "IT Intern", "authority": "learning", "reportsTo": "Helpdesk Technician" }
      ]
    }
  },
  "departments": [
    "Engineering",
    "Product",
    "Design",
    "QA",
    "DevOps",
    "Security",
    "Data",
    "Sales",
    "Marketing",
    "IT Support",
    "Customer Success"
  ],
  "escalation": {
    "tiers": [
      { "tier": 1, "from": ["Intern", "Junior Engineer", "Junior Developer", "QA Intern", "DevOps Intern", "Data Intern"], "to": ["Team Lead", "Tech Lead", "QA Lead"], "timeout": "24h" },
      { "tier": 2, "from": ["Team Lead", "Tech Lead", "QA Lead", "Engineering Manager", "Product Manager"], "to": ["Director Engineering", "Product Director", "QA Director"], "timeout": "48h" },
      { "tier": 3, "from": ["Director Engineering", "VP Engineering", "Product Director", "VP Product", "Sales Manager"], "to": ["CTO", "CEO", "VP Sales"], "timeout": "72h" }
    ],
    "triggers": [
      "priority_critical",
      "budget_exceeded",
      "timeline_at_risk",
      "security_breach",
      "resource_conflict"
    ],
    "security_escalation": {
      "triggers": ["security_incident", "data_breach", "critical_vulnerability"],
      "immediate_to": "CISO"
    }
  },
  "routing": {
    "default_strategy": "skill_match",
    "fallback_strategy": "round_robin",
    "filters": ["priority", "department", "skill_required"]
  },
  "audit": {
    "enabled": true,
    "frequency": "weekly",
    "recipients": ["CEO"],
    "formats": ["json", "pdf", "html"]
  },
  "deployment": {
    "approval_levels": [
      { "level": 1, "role": "Team Lead", "environment": "development" },
      { "level": 2, "role": "Manager", "environment": "staging" },
      { "level": 3, "role": "Director", "environment": "production" },
      { "level": 4, "role": "CTO", "environment": "production_critical" }
    ]
  }
}