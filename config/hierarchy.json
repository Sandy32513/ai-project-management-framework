      "levels": [
        { "role": "CEO", "authority": "company_wide", "reportsTo": null },
        { "role": "CTO", "authority": "technology", "reportsTo": "CEO" },
        { "role": "CIO", "authority": "internal_it", "reportsTo": "CEO" },
        { "role": "CFO", "authority": "financial", "reportsTo": "CEO" },
        { "role": "COO", "authority": "operations", "reportsTo": "CEO" },
