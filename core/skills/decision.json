{
  "decision_framework": {
    "name": "AI Decision-Making Framework",
    "version": "1.0.0",
    "description": "Pre-defined decision-making authority and logic for each role level"
  },
  "decision_levels": [
    {
      "level": 1,
      "authority": "routine",
      "roles": ["Intern", "Junior Engineer", "Junior Developer", "QA Intern", "DevOps Intern", "Helpdesk Technician"],
      "threshold": "low_impact",
      "decision_types": [
        "task_completion",
        "basic_troubleshooting",
        "documentation_updates",
        "simple_feature_implementation"
      ],
      "budget_limit": 0,
      "time_limit": "1d"
    },
    {
      "level": 2,
      "authority": "standard",
      "roles": ["Mid-Level Engineer", "Software Engineer", "QA Engineer", "DevOps Engineer", "IT Support Engineer", "Data Analyst"],
      "threshold": "low_medium_impact",
      "decision_types": [
        "feature_implementation_approach",
        "code_review_decisions",
        "test_strategy",
        "deployment_configuration"
      ],
      "budget_limit": 1000,
      "time_limit": "3d"
    },
    {
      "level": 3,
      "authority": "complex",
      "roles": ["Senior Engineer", "Senior Developer", "Tech Lead", "Team Lead", "QA Lead", "Senior QA Engineer", "Security Engineer"],
      "threshold": "medium_impact",
      "decision_types": [
        "technical_architecture",
        "code_approval",
        "test_plan_approval",
        "deployment_approval",
        "performance_optimization",
        "security_assessment"
      ],
      "budget_limit": 10000,
      "time_limit": "1w"
    },
    {
      "level": 4,
      "authority": "strategic",
      "roles": ["Manager", "Engineering Manager", "Product Manager", "DevOps Lead", "UX Lead", "Sales Manager"],
      "threshold": "medium_high_impact",
      "decision_types": [
        "project_prioritization",
        "resource_allocation",
        "timeline_adjustments",
        "sprint_planning",
        "team_performance_decisions"
      ],
      "budget_limit": 50000,
      "time_limit": "2w"
    },
    {
      "level": 5,
      "authority": "executive",
      "roles": ["Director", "VP", "VP Engineering", "Product Director", "Design Director"],
      "threshold": "high_impact",
      "decision_types": [
        "department_strategy",
        "budget_allocation",
        "hiring_decisions",
        "roadmap_prioritization",
        "stakeholder_management"
      ],
      "budget_limit": 500000,
      "time_limit": "1m"
    },
    {
      "level": 6,
      "authority": "company_wide",
      "roles": ["CEO", "CTO", "CFO", "COO", "CCO", "CIO", "CISO"],
      "threshold": "critical_impact",
      "decision_types": [
        "company_strategy",
        "major_budget",
        "acquisitions",
        "partnerships",
        "board_matters",
        "crisis_management"
      ],
      "budget_limit": null,
      "time_limit": null
    }
  ],
  "decision_routing": {
    "auto_routing": {
      "enabled": true,
      "logic": "Decision is routed to the lowest level with sufficient authority"
    },
    "escalation_triggers": [
      {
        "trigger": "budget_exceeds_limit",
        "action": "escalate_to_next_level"
      },
      {
        "trigger": "strategic_impact",
        "action": "escalate_to_executive"
      },
      {
        "trigger": "stakeholder_conflict",
        "action": "escalate_to_manager"
      },
      {
        "trigger": "legal_implications",
        "action": "escalate_to_c_suite"
      }
    ]
  },
  "decision_matrices": {
    "project_approval": {
      "criteria": [
        { "factor": "budget", "thresholds": ["<10k", "10k-50k", "50k-500k", ">500k"] },
        { "factor": "timeline", "thresholds": ["<1m", "1-3m", "3-6m", ">6m"] },
        { "factor": "team_size", "thresholds": ["1-3", "4-10", "10-50", ">50"] },
        { "factor": "strategic_impact", "thresholds": ["low", "medium", "high", "critical"] }
      ],
      "approval_chain": [
        { "budget_range": "<10k", "approver": "Manager" },
        { "budget_range": "10k-50k", "approver": "Director" },
        { "budget_range": "50k-500k", "approver": "VP" },
        { "budget_range": ">500k", "approver": "C-Suite" }
      ]
    },
    "risk_acceptance": {
      "thresholds": [
        { "risk_level": "low", "approver": "Manager" },
        { "risk_level": "medium", "approver": "Director" },
        { "risk_level": "high", "approver": "VP" },
        { "risk_level": "critical", "approver": "C-Suite" }
      ]
    },
    "contract_approval": {
      "thresholds": [
        { "value": "<10k", "approver": "Manager" },
        { "value": "10k-50k", "approver": "Director" },
        { "value": "50k-250k", "approver": "VP" },
        { "value": ">250k", "approver": "C-Suite + Legal" }
      ]
    }
  },
  "automatic_decisions": {
    "enabled": true,
    "auto_approve_conditions": [
      {
        "condition": "all_tests_pass",
        "action": "auto_approve_deployment_to_staging"
      },
      {
        "condition": "security_scan_clean",
        "action": "auto_approve_deployment_to_staging"
      },
      {
        "condition": "code_review_approved",
        "action": "auto_merge_to_development"
      },
      {
        "condition": "documentation_complete",
        "action": "auto_mark_feature_ready"
      }
    ]
  }
}